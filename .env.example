APP_NAME="DhanSutra"
ENVIRONMENT="local"
DEBUG="true"

# SECURITY
JWT_ISSUER="dhansutra"
JWT_AUDIENCE="dhansutra-mobile"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="15"
JWT_REFRESH_TOKEN_EXPIRE_DAYS="30"
JWT_SECRET_KEY="change-me-in-local-env"

# DATABASE
# App uses async URL; Alembic uses a sync URL derived from this.
DATABASE_URL="sqlite+aiosqlite:///./finance.db"

# LOGGING
LOG_LEVEL="INFO"
LOG_JSON="true"

